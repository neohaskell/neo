cabal-version: 3.4
name: {{ name }}
version: {{ version }}
{% if description %}description: {{ description }}{% endif %}
homepage: https://neohaskell.org
license: {{ license }}
author: {{ author }}
category: Development
build-type: Simple

common common_cfg
  ghc-options:
    -Wall
    -Wno-orphans
    -threaded
    -fno-warn-partial-type-signatures
    -fno-warn-name-shadowing
    -Werror

  default-extensions:
    ApplicativeDo
    BlockArguments
    DataKinds
    DeriveDataTypeable
    DuplicateRecordFields
    ImportQualifiedPost
    ImpredicativeTypes
    NamedFieldPuns
    NoFieldSelectors
    NoImplicitPrelude
    OverloadedLabels
    OverloadedLists
    OverloadedRecordDot
    OverloadedStrings
    PackageImports
    PartialTypeSignatures
    QualifiedDo
    QuasiQuotes
    Strict
    TemplateHaskell
    TypeApplications
    TypeFamilies
    TypeOperators

  build-depends:
    base,
    nhcore,
    nhintegrations,
    aeson,
    bytestring,
    text,
    uuid,
{% for dep, ver in dependencies %}
    {{ dep }} {{ ver }},
{% endfor %}

library
  import: common_cfg
  exposed-modules:
{% for module in modules %}
    {{ module }}
{% endfor %}
  hs-source-dirs: src
  default-language: GHC2021

executable {{ name }}
  import: common_cfg
  main-is: Launcher.hs
  build-depends:
    base,
    {{ name }}
  hs-source-dirs: launcher
  default-language: GHC2021
